# ─────────────────────────────────────────────────────────────────────────────
# Пример безопасного проброса ТОЛЬКО ссылок на скачивание установщика (/d/...)
# наружу, в интернет. Вся остальная панель (/api, /, дашборд) НЕ публикуется.
#
# Установка:
#   apt install nginx
#   cp nginx-download.conf.example /etc/nginx/sites-available/clickvpn-download
#   ln -s /etc/nginx/sites-available/clickvpn-download /etc/nginx/sites-enabled/
#   # отредактируйте server_name и пути к сертификатам
#   nginx -t && systemctl reload nginx
#
# В настройках панели укажите «Публичный адрес»: https://vpn.company.ru
# ─────────────────────────────────────────────────────────────────────────────

# Ограничение частоты запросов к ссылкам (защита от перебора токенов)
limit_req_zone $binary_remote_addr zone=clickvpn_dl:10m rate=10r/m;

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name vpn.company.ru;            # ← ВАШ домен

    # TLS-сертификаты (Let's Encrypt / self-signed)
    ssl_certificate     /etc/letsencrypt/live/vpn.company.ru/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/vpn.company.ru/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;

    # Лимит размера ответа не нужен; .exe ~15 МБ
    client_max_body_size 1m;

    # ── ЕДИНСТВЕННЫЙ открытый путь: скачивание установщика по токену ──────────
    location ~ ^/d/[A-Za-z0-9_-]+$ {
        limit_req zone=clickvpn_dl burst=5 nodelay;
        proxy_pass http://127.0.0.1:8080;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_set_header X-Forwarded-Proto https;
        proxy_read_timeout 180s;           # сборка .exe может занять время
    }

    # ── Всё остальное закрыто ────────────────────────────────────────────────
    location / {
        return 404;
    }
}

# HTTP → HTTPS (необязательно, но желательно)
server {
    listen 80;
    listen [::]:80;
    server_name vpn.company.ru;
    return 301 https://$host$request_uri;
}
