# Скопируйте в .env и заполните

# Обязательно смените на случайную строку (openssl rand -hex 32)
SECRET_KEY=change-me-please-use-strong-random-key

# Ключ шифрования секретов в БД (приватные ключи, пароли). openssl rand -hex 32
# Если не задан — используется SECRET_KEY. НЕ МЕНЯЙТЕ после первого запуска,
# иначе ранее зашифрованные данные станут нечитаемыми!
# DB_ENCRYPTION_KEY=change-me-too

# Пароль первого admin пользователя (создаётся при первом запуске)
ADMIN_PASSWORD=admin

# Время жизни токена в минутах (480 = 8 часов)
TOKEN_EXPIRE_MINUTES=480

# Для PostgreSQL вместо SQLite:
# DATABASE_URL=postgresql://vpnuser:password@localhost:5432/vpndb
