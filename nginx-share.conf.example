# ─────────────────────────────────────────────────────────────────────────────
# Проброс ТОЛЬКО изолированного сервиса раздачи ссылок (/s/...) наружу.
# Основная панель НЕ публикуется. Сервис раздачи работает под отдельным
# пользователем без доступа к БД/ключам (см. install-share-service.sh).
#
#   cp nginx-share.conf.example /etc/nginx/sites-available/clickvpn-share
#   ln -s /etc/nginx/sites-available/clickvpn-share /etc/nginx/sites-enabled/
#   # отредактируйте server_name и сертификаты
#   nginx -t && systemctl reload nginx
#
# В настройках панели «Публичный адрес»: https://vpn.company.ru
# ─────────────────────────────────────────────────────────────────────────────

limit_req_zone $binary_remote_addr zone=clickvpn_share:10m rate=20r/m;

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name _;                         # любой Host — подходит для доступа по WAN IP

    # ── Вариант 1: домен + Let's Encrypt ─────────────────────────────────────
    # ssl_certificate     /etc/letsencrypt/live/vpn.company.ru/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/vpn.company.ru/privkey.pem;

    # ── Вариант 2: доступ по WAN IP, self-signed (создаёт install-share-service.sh) ──
    ssl_certificate     /etc/click-vpn/share-cert.pem;
    ssl_certificate_key /etc/click-vpn/share-key.pem;

    ssl_protocols TLSv1.2 TLSv1.3;

    # ── Единственный открытый путь: раздача ссылок ───────────────────────────
    location ~ ^/s/[A-Za-z0-9_-]+(/dl)?$ {
        limit_req zone=clickvpn_share burst=10 nodelay;
        proxy_pass http://127.0.0.1:8081;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_read_timeout 120s;
    }

    # ── Всё остальное закрыто ────────────────────────────────────────────────
    location / {
        return 404;
    }
}

# HTTP → HTTPS (по IP или домену)
server {
    listen 80;
    listen [::]:80;
    server_name _;
    return 301 https://$host$request_uri;
}
